    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jsdom": "^27.0.1",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  }
}
